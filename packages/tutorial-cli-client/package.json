{
  "name": "@bodhiapp/tutorial-cli-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Hands-on tutorial: a minimal Node CLI we will grow into a web-acp-agent host.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=list",
    "ci:test:e2e": "cross-env CI=true playwright test",
    "check": "tsc --noEmit && tsc -p tsconfig.e2e.json --noEmit"
  },
  "devDependencies": {
    "@bodhiapp/app-bindings": "0.0.42",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.10.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "playwright": "^1.57.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^4.0.16"
  }
}
