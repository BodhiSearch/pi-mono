{
  "name": "@bodhiapp/tutorial-cli-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Hands-on tutorial: a minimal Node CLI we will grow into a web-acp-agent host.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "test:e2e": "playwright test --reporter=list",
    "ci:test:e2e": "cross-env CI=true playwright test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b && tsc -p tsconfig.e2e.json --noEmit",
    "check": "npm run lint && npm run typecheck",
    "check:fix": "npm run lint:fix && npm run typecheck"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@bodhiapp/web-acp-agent": "*",
    "@mariozechner/pi-agent-core": "^0.67.3",
    "@mariozechner/pi-ai": "^0.67.3"
  },
  "devDependencies": {
    "@bodhiapp/app-bindings": "0.0.42",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22.10.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.0.0",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.4"
  }
}
