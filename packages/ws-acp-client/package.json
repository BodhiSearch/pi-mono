{
  "name": "@bodhiapp/ws-acp-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "WebSocket host runtime for @bodhiapp/web-acp-agent.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "ws-acp-client": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "ci:test:e2e": "cross-env CI=true playwright test",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@bodhiapp/web-acp-agent": "*",
    "@mariozechner/pi-agent-core": "^0.67.3",
    "@mariozechner/pi-ai": "^0.67.3",
    "@zenfs/core": "~2.5.6",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@bodhiapp/app-bindings": "0.0.42",
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.5.13",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.57.0",
    "tsx": "^4.20.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.16"
  }
}
