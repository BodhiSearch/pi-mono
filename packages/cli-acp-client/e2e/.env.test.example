# Copy to .env.test and fill in. Mirror the contract used by
# packages/web-acp/e2e/.env.test — credentials are shared across packages.

# BodhiApp public OAuth client (server-side; for the CLI's hardcoded
# client we use a separate public client; see src/auth/config.ts).
BODHIAPP_CLIENT_ID=
BODHIAPP_CLIENT_SECRET=

# BodhiApp admin user (used in global-setup to register API models).
BODHIAPP_USERNAME=
BODHIAPP_PASSWORD=
BODHIAPP_USERID=

# Keycloak realm hosting BodhiApp's auth.
BODHIAPP_AUTH_URL=https://main-id.getbodhi.app
BODHIAPP_AUTH_REALM=bodhi

# LLM API keys used to register API models on BodhiApp during setup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: bin path to the BodhiApp NAPI binary lookup root. If unset,
# falls back to the default packaged location.
# BODHI_BIN_PATH=
