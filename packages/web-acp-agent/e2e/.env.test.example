# Copy to .env.test and fill in real values. Do not commit secrets.
#
# These keys are required by `e2e/tests/global-setup.ts` to:
#   - boot a local BodhiApp server (NAPI bindings + admin client creds)
#   - drive Keycloak OAuth via headless Chromium and capture a JWT
#   - register an OpenAI API model so prompts can round-trip

BODHIAPP_USERNAME=
BODHIAPP_USERID=
BODHIAPP_PASSWORD=

BODHIAPP_CLIENT_ID=
BODHIAPP_CLIENT_SECRET=
BODHIAPP_AUTH_URL=https://main-id.getbodhi.app
BODHIAPP_AUTH_REALM=bodhi

OPENAI_API_KEY=
